# Example secrets for OpenClaw deployment.
# Copy this file to secrets.yaml, fill in real values, and apply:
#   kubectl apply -f secrets.yaml
#
# Alternatively, use ExternalSecrets, Vault, SOPS, or any other
# secret management solution that creates these two Secret resources.
apiVersion: v1
kind: Secret
metadata:
  name: openclaw-gateway-token
  namespace: openclaw
type: Opaque
stringData:
  OPENCLAW_GATEWAY_TOKEN: "<generate-a-random-token>"
---
apiVersion: v1
kind: Secret
metadata:
  name: claude-api-key
  namespace: openclaw
type: Opaque
stringData:
  ANTHROPIC_API_KEY: "<your-anthropic-api-key>"
